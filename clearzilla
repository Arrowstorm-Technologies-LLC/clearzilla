#!/usr/bin/env bash
# clearzilla — Godzilla stomps in and fire-breaths your terminal clean
# Lightweight, dependency-free. Animation scales with terminal content.

set -euo pipefail

VERSION="0.3.5"

# ── styling ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  YELLOW="\033[1;33m"
  RED="\033[1;31m"
  ORANGE="\033[38;5;208m"
  ASH="\033[38;5;243m"
  RUBBLE="\033[38;5;238m"
  RESET="\033[0m"
  HIDE_CURSOR=$'\033[?25l'
  SHOW_CURSOR=$'\033[?25h'
else
  BOLD="" DIM="" GREEN="" YELLOW="" RED="" ORANGE="" ASH="" RUBBLE="" RESET=""
  HIDE_CURSOR="" SHOW_CURSOR=""
fi

