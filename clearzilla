#!/usr/bin/env bash
# clearzilla — Godzilla fire-breaths your terminal clean
# Detailed head fixed on the left, facing right. Flame fans outward and
# clears characters only as the fire front reaches them.

set -euo pipefail

VERSION="0.6.0"

# ── styling ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  DGREEN="\033[32m"
  YELLOW="\033[1;33m"
  RED="\033[1;31m"
  ORANGE="\033[38;5;208m"
  HOT="\033[38;5;226m"
  CORE="\033[38;5;196m"
  RESET="\033[0m"
  HIDE_CURSOR=$'\033[?25l'
  SHOW_CURSOR=$'\033[?25h'
else
  BOLD="" DIM="" GREEN="" DGREEN="" YELLOW="" RED="" ORANGE="" HOT="" CORE="" RESET=""
  HIDE_CURSOR="" SHOW_CURSOR=""
fi

# ── godzilla head — wide right-facing profile, flush left ───────────────────
# Mouth closed (idle) — enlarged eye, lips sealed shut
readonly -a ZILLA_HEAD_CLOSED=(
  '/|/|/|/|/|'
  '|             /'
  '| .-----------. /'
  '|/  (  @  )      /'
  '||       \         /'
  '||        \════════|'
  '| \      /█████████|'
  '|  |    |══■■■■■══|'
  '|  |     \█████████|'
  '|   \        ‾‾‾‾‾‾‾|'
  '|    |_______________|'
)

# Mouth open (breathing fire) — head tilted back, lower jaw dropped (pac-man hinge)
readonly -a ZILLA_HEAD_OPEN=(
  ' /|/|/|/|/|'
  '|            /'
  '| .----------. /'
  '|/  (  @  )     /'
  '||      \_______/'
  '|            /'
  '|    /██     ████>>'
  '|   |>■       ■<|'
  '|    \██     ███/|'
  '|      \_________|'
  '|   |____________|'
)

readonly HEAD_H=${#ZILLA_HEAD_CLOSED[@]}

_sprite_width() {
  local -n _lines=$1
  local w=0 len
  for _l in "${_lines[@]}"; do
    len=${#_l}
    (( len > w )) && w=$len
  done
  echo "$w"
}

_sprite_max_width() {
  local w1 w2
  w1=$(_sprite_width "$1")
  w2=$(_sprite_width "$2")
  (( w1 > w2 )) && echo "$w1" || echo "$w2"
}

readonly HEAD_W=$(_sprite_max_width ZILLA_HEAD_CLOSED ZILLA_HEAD_OPEN)
# Mouth emitter offsets within each sprite (0-based row, column from col 1)
readonly MOUTH_ROW_CLOSED=6
readonly MOUTH_COL_CLOSED=20
readonly MOUTH_ROW_OPEN=6
readonly MOUTH_COL_OPEN=18

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} — Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Godzilla's head stays fixed on the left, facing right. His flame fans
outward, clearing characters only as the fire front reaches them.
EOF
}

# ── terminal helpers ──────────────────────────────────────────────────────────
get_dims() {
  local size rows cols
  rows=0 cols=0
  size=$(stty size 2>/dev/null || true)
  if [[ -n "$size" ]]; then
    rows=${size%% *}
    cols=${size##* }
  fi
  (( rows < 1 )) && rows=${LINES:-$(tput lines 2>/dev/null || echo 24)}
  (( cols < 1 )) && cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  (( rows < 1 )) && rows=24
  (( cols < 1 )) && cols=80
  TERM_ROWS=$rows
  TERM_COLS=$cols
}

get_content_lines() {
  local row=0
  if [[ -t 1 ]] && exec 3<>/dev/tty 2>/dev/null; then
    printf '\033[6n' >&3
    IFS=';' read -rsd R -t 0.05 _ row <&3 2>/dev/null || true
    exec 3>&-
  fi
  if [[ -z "$row" || "$row" -eq 0 ]]; then
    row=$TERM_ROWS
  elif (( row > TERM_ROWS )); then
    row=$TERM_ROWS
  fi
  CONTENT_LINES=$row
}

frame_delay() {
  local ms=$(( (20 + CONTENT_LINES / 3) / SPEED ))
  (( ms < 2 )) && ms=2
  sleep "0.$(printf '%03d' "$ms")"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

clear_screen() {
  printf '\033[2J\033[H'
}

erase_head() {
  local top_row=$1
  local blank i
  blank=$(printf '%*s' "$HEAD_W" '')
  for ((i = 0; i < HEAD_H; i++)); do
    move_to $((top_row + i)) 1
    printf '%s' "$blank"
  done
}

draw_head() {
  local top_row=$1 mouth_open=$2
  local i=0 line

  erase_head "$top_row"

  if (( mouth_open )); then
    for line in "${ZILLA_HEAD_OPEN[@]}"; do
      move_to $((top_row + i)) 1
      printf '%b%s%b' "$GREEN" "$line" "$RESET"
      ((${#line} < HEAD_W)) && printf '%*s' $((HEAD_W - ${#line})) ''
      ((i++)) || true
    done
  else
    for line in "${ZILLA_HEAD_CLOSED[@]}"; do
      move_to $((top_row + i)) 1
      printf '%b%s%b' "$GREEN" "$line" "$RESET"
      ((${#line} < HEAD_W)) && printf '%*s' $((HEAD_W - ${#line})) ''
      ((i++)) || true
    done
  fi
}

# Cone half-width grows as flame travels right from the mouth
fan_half_width() {
  local dist=$1 max_spread=$2 frame=$3
  local spread=$(( 1 + dist / 2 + (dist * 3 + frame * 2) % 3 ))
  (( spread > max_spread )) && spread=$max_spread
  echo "$spread"
}

fire_char() {
  local dist=$1 slot=$2
  local ch color
  if (( dist < 4 )); then
    case $((slot % 4)) in
      0) ch='#'; color=$HOT ;;
      1) ch='*'; color=$YELLOW ;;
      2) ch='#'; color=$CORE ;;
      *) ch='*'; color=$ORANGE ;;
    esac
  elif (( dist < 12 )); then
    case $((slot % 5)) in
      0) ch='~'; color=$ORANGE ;;
      1) ch='='; color=$RED ;;
      2) ch='^'; color=$YELLOW ;;
      3) ch='*'; color=$ORANGE ;;
      *) ch='#'; color=$RED ;;
    esac
  else
    case $((slot % 4)) in
      0) ch='~'; color=$RED ;;
      1) ch='>'; color=$ORANGE ;;
      2) ch='^'; color=$RED ;;
      *) ch='='; color=$YELLOW ;;
    esac
  fi
  printf '%b%s%b' "$color" "$ch" "$RESET"
}

# ── animation ─────────────────────────────────────────────────────────────────
animate() {
  get_dims
  get_content_lines

  local head_row=$(( (CONTENT_LINES - HEAD_H) / 2 + 1 ))
  (( head_row < 1 )) && head_row=1
  if (( head_row + HEAD_H - 1 > TERM_ROWS )); then
    head_row=$(( TERM_ROWS - HEAD_H + 1 ))
  fi

  local mouth_row mouth_col max_spread max_reach reach frame=0
  local col row dist spread row_off d burn_start front_col
  local breathing=0

  local max_spread=$(( CONTENT_LINES / 2 + 1 ))
  (( max_spread < 3 )) && max_spread=3
  (( max_spread > TERM_ROWS / 2 )) && max_spread=$(( TERM_ROWS / 2 ))

  # Fire erupts from the tilted-back open mouth position
  mouth_row=$(( head_row + MOUTH_ROW_OPEN ))
  mouth_col=$MOUTH_COL_OPEN
  max_reach=$(( TERM_COLS - mouth_col ))
  (( max_reach < 1 )) && max_reach=1
  burn_start=$(( mouth_col + 1 ))

  printf '%s' "$HIDE_CURSOR"
  draw_head "$head_row" 0

  for ((reach = 1; reach <= max_reach; reach++)); do
    breathing=1
    front_col=$(( mouth_col + reach ))

    # Scorch trail — columns the flame has already passed
    for ((d = 1; d < reach; d++)); do
      col=$(( mouth_col + d ))
      (( col > TERM_COLS )) && continue
      spread=$(fan_half_width "$d" "$max_spread" "$frame")
      for ((row_off = -spread; row_off <= spread; row_off++)); do
        row=$(( mouth_row + row_off ))
        (( row < 1 || row > CONTENT_LINES )) && continue
        move_to "$row" "$col"
        printf ' '
      done
    done

    # Nozzle glow at the mouth (always visible)
    for ((d = 0; d < 3; d++)); do
      col=$(( mouth_col + d ))
      (( col < burn_start )) && continue
      (( col > TERM_COLS )) && continue
      spread=1
      for ((row_off = -spread; row_off <= spread; row_off++)); do
        row=$(( mouth_row + row_off ))
        (( row < 1 || row > CONTENT_LINES )) && continue
        move_to "$row" "$col"
        fire_char "$d" "$((frame + row_off))"
      done
    done

    # Leading fire front — fan expands with distance
    if (( front_col <= TERM_COLS )); then
      spread=$(fan_half_width "$reach" "$max_spread" "$frame")
      for ((row_off = -spread; row_off <= spread; row_off++)); do
        row=$(( mouth_row + row_off ))
        (( row < 1 || row > CONTENT_LINES )) && continue
        move_to "$row" "$front_col"
        fire_char "$reach" "$((frame + row_off))"
      done

      # Fill the cone between mouth and front with flame (the visible fan body)
      for ((d = 1; d < reach; d++)); do
        col=$(( mouth_col + d ))
        (( col > TERM_COLS )) && continue
        spread=$(fan_half_width "$d" "$max_spread" "$frame")
        for ((row_off = -spread; row_off <= spread; row_off++)); do
          row=$(( mouth_row + row_off ))
          (( row < 1 || row > CONTENT_LINES )) && continue
          # Leave the scorched trail blank; only paint near-front embers
          (( d < reach - 2 )) && continue
          move_to "$row" "$col"
          fire_char "$d" "$((frame + row_off + d))"
        done
      done

      # Outer wisps one step ahead of the front (visible but not yet clearing)
      if (( front_col < TERM_COLS )); then
        d=$(( reach + 1 ))
        spread=$(fan_half_width "$d" "$max_spread" "$frame")
        wisp_spread=$(( spread + 1 ))
        for ((row_off = -wisp_spread; row_off <= wisp_spread; row_off++)); do
          inner=$(fan_half_width "$d" "$max_spread" "$frame")
          (( row_off >= -inner && row_off <= inner )) && continue
          row=$(( mouth_row + row_off ))
          (( row < 1 || row > CONTENT_LINES )) && continue
          move_to "$row" $((front_col + 1))
          printf '%b~%b' "$ORANGE" "$RESET"
        done
      fi
    fi

    draw_head "$head_row" "$breathing"
    frame_delay
    ((frame++)) || true
  done

  # Snap jaw shut, then burn remaining fan area
  draw_head "$head_row" 0
  frame_delay

  # Burn remaining fan area, then reset
  for ((d = 1; d <= max_reach; d++)); do
    col=$(( mouth_col + d ))
    (( col > TERM_COLS )) && continue
    spread=$(fan_half_width "$d" "$max_spread" "$frame")
    for ((row_off = -spread; row_off <= spread; row_off++)); do
      row=$(( mouth_row + row_off ))
      (( row < 1 || row > CONTENT_LINES )) && continue
      move_to "$row" "$col"
      printf ' '
    done
  done

  printf '%s' "$SHOW_CURSOR"
  clear_screen
}

# ── main ──────────────────────────────────────────────────────────────────────
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

animate