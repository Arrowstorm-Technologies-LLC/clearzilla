readonly -a ZILLA_WALK1=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_WALK2=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_BREATH=("${ZILLA_SPRITE[@]}")

readonly ZILLA_H=${#ZILLA_SPRITE[@]}

_sprite_width() {
  local -n _lines=$1
  local w=0
  for _l in "${_lines[@]}"; do
    ((${#_l} > w)) && w=${#_l}
  done
  echo "$w"
}

readonly ZILLA_W=$(_sprite_width ZILLA_SPRITE)
readonly MOUTH_COL=14   # column offset from sprite origin to fire origin (snout)
readonly ENABLE_FIRE=0  # fire breath disabled for now

readonly -a DEBRIS_CHARS=( '░' '▒' '▓' ':' '.' ',' '`' '~' '%' '#' '*' '+' 'x' '°' )
readonly DEBRIS_MIN=2
readonly DEBRIS_MAX=5
readonly DEBRIS_ANIM_INTERVAL=4
readonly DEBRIS_ANIM_TAIL=28   # only animate debris in this many cols behind sprite

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} — Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Godzilla sweeps the visible terminal band by band until clear.
EOF
}

# ── terminal helpers ──────────────────────────────────────────────────────────
get_dims() {
  local size rows cols
  rows=0 cols=0
  size=$(stty size 2>/dev/null || true)
  if [[ -n "$size" ]]; then
    rows=${size%% *}
    cols=${size##* }
  fi
  (( rows < 1 )) && rows=${LINES:-$(tput lines 2>/dev/null || echo 24)}
  (( cols < 1 )) && cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  (( rows < 1 )) && rows=24
  (( cols < 1 )) && cols=80
  (( rows > 128 )) && rows=128
  (( cols > 512 )) && cols=512
  TERM_ROWS=$rows
  TERM_COLS=$cols
}

band_height() {
  local band_row=$1
  local h=$(( TERM_ROWS - band_row + 1 ))
  (( h > ZILLA_H )) && h=$ZILLA_H
  (( h < 1 )) && h=1
  echo "$h"
}

frame_delay() {
  local ms=$(( 25 / SPEED ))
  (( ms < 2 )) && ms=2
  sleep "0.$(printf '%03d' "$ms")"
}

breath_delay() {
  local ms=$(( 60 / SPEED ))
  (( ms < 4 )) && ms=4
  sleep "0.$(printf '%03d' "$ms")"
}

walk_stride() {
  local stride=$SPEED
  (( stride < 2 )) && stride=2
  echo "$stride"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

draw_sprite() {
  local -n lines=$1
  local row=$2 col=$3
  local h=${4:-$ZILLA_H}
  local i=0
  for line in "${lines[@]}"; do
    (( i >= h )) && break
    move_to $((row + i)) "$col"
    printf '%s' "$line"
    ((i++)) || true
  done
}

erase_sprite() {
  local row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local blank
  blank=$(printf '%*s' "$ZILLA_W" '')
  local i
  for ((i = 0; i < h; i++)); do
    move_to $((row + i)) "$col"
    printf '%s' "$blank"
  done
}

# Blank only the overlap zone the next stomp will redraw — leave the wake slice alone.
erase_sprite_overlap() {
  local row=$1 col=$2 stride=$3
  local h=${4:-$ZILLA_H}
  local erase_col=$(( col + stride ))
  local erase_w=$(( ZILLA_W - stride ))
  local blank i
  (( erase_w < 1 )) && return 0
  blank=$(printf '%*s' "$erase_w" '')
  for ((i = 0; i < h; i++)); do
    move_to $((row + i)) "$erase_col"
    printf '%s' "$blank"
  done
}

# Sparse ash particles — stored globally and animated until the final clear.
declare -a DEBRIS_SITES=()

debris_color() {
  local seed=$1 tick=$2
  case $(((seed + tick * 3) % 14)) in
    0) printf '%s' "$ORANGE" ;;
    1) printf '%s' "$RED" ;;
    2|3|4) printf '%s' "$ASH" ;;
    *) printf '%s' "$RUBBLE" ;;
  esac
}

debris_glyph() {
  local seed=$1 tick=$2
  local idx=$(( (seed + tick * 5) % ${#DEBRIS_CHARS[@]} ))
  printf '%s' "${DEBRIS_CHARS[$idx]}"
}

draw_debris_particle() {
  local r=$1 c=$2 seed=$3 tick=$4
  local ch color
  move_to "$r" "$c"
  ch=$(debris_glyph "$seed" "$tick")
  color=$(debris_color "$seed" "$tick")
  printf '%b%s%b' "$color" "$ch" "$RESET"
}

# During a walk, only smolder the narrow wake directly behind Godzilla.
# Older bands and settled ash are drawn once and left static.
animate_debris() {
  local tick=$1
  local band_row=${2:-0} band_x=${3:-0} band_h=${4:-0}
  local site r c seed site_band tail_start ch color
  local wake_only=0
  (( band_h > 0 )) && wake_only=1
  tail_start=$(( band_x - DEBRIS_ANIM_TAIL ))
  (( tail_start < 1 )) && tail_start=1

  for site in "${DEBRIS_SITES[@]}"; do
    read -r r c seed site_band <<< "$site"
    if (( wake_only )); then
      if (( site_band != band_row )); then
        continue
      fi
      if (( r < band_row || r >= band_row + band_h || c >= band_x || c < tail_start )); then
        continue
      fi
    fi
    ch=$(debris_glyph "$seed" "$tick")
    move_to "$r" "$c"
    color=$(debris_color "$seed" "$tick")
    printf '%b%s%b' "$color" "$ch" "$RESET"
  done
}

scatter_debris() {
  local band_row=$1 col=$2 stride=$3
  local h=${4:-$ZILLA_H} tick=${5:-0}
  local wake_w=$stride
  local count=$(( DEBRIS_MIN + RANDOM % (DEBRIS_MAX - DEBRIS_MIN + 1) ))
  local i r c seed
  (( wake_w > ZILLA_W )) && wake_w=$ZILLA_W
  (( wake_w < 1 )) && wake_w=1
  for ((i = 0; i < count; i++)); do
    r=$(( band_row + RANDOM % h ))
    c=$(( col + RANDOM % wake_w ))
    seed=$(( RANDOM * 997 + r * 31 + c * 17 + i * 13 ))
    DEBRIS_SITES+=( "$r $c $seed $band_row" )
    draw_debris_particle "$r" "$c" "$seed" "$tick"
  done
}

draw_fire_beam() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local fire_len=$((TERM_COLS - col + 1))
  local i j
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) "$col"
    for ((j = 0; j < fire_len; j++)); do
      case $((j % 4)) in
        0) printf '%b~%b' "$RED" "$RESET" ;;
        1) printf '%b=%b' "$ORANGE" "$RESET" ;;
        2) printf '%b*%b' "$YELLOW" "$RESET" ;;
        3) printf '%b>%b' "$RED" "$RESET" ;;
      esac
    done
  done
}

scorch_band_right() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local fire_len=$((TERM_COLS - col + 1))
  local i
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) "$col"
    printf '%*s' "$fire_len" ''
  done
}

scorch_band() {
  local band_row=$1
  local h=${2:-$ZILLA_H}
  local i
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) 1
    printf '%*s' "$TERM_COLS" ''
  done
}

clear_screen() {
  printf '\033[2J\033[H'
}

# ── animation (paclear-style band sweep) ──────────────────────────────────────
# Godzilla is ZILLA_H lines tall. Each horizontal pass clears one full band
# before stepping down to the next band — exactly like paclear's pac-man sweep.
animate() {
  get_dims

  local diff_y=$(( TERM_ROWS - ZILLA_H ))
  (( diff_y < 0 )) && diff_y=0

  local y x frame=0 toggle=0 stride max_x walk_step=0 debris_tick=0
  local fire_col band_row band_h

  stride=$(walk_stride)
  max_x=$(( TERM_COLS - ZILLA_W ))
  (( max_x < 1 )) && max_x=1

  DEBRIS_SITES=()
  printf '%s' "$HIDE_CURSOR"

  for ((y = 0; y <= diff_y; y += ZILLA_H)); do
    band_row=$((y + 1))
    band_h=$(band_height "$band_row")

    for ((x = 1; x <= max_x; x += stride)); do
      ((walk_step++)) || true

      if (( ENABLE_FIRE && toggle == 10 )); then
        draw_sprite ZILLA_BREATH "$band_row" "$x" "$band_h"
        fire_col=$((x + MOUTH_COL))
        draw_fire_beam "$band_row" "$fire_col" "$band_h"
        breath_delay
        scorch_band_right "$band_row" "$fire_col" "$band_h"
        erase_sprite_overlap "$band_row" "$x" "$stride" "$band_h"
        scatter_debris "$band_row" "$x" "$stride" "$band_h" "$debris_tick"
        toggle=0
      else
        draw_sprite ZILLA_WALK1 "$band_row" "$x" "$band_h"
        if (( walk_step % DEBRIS_ANIM_INTERVAL == 0 )); then
          ((debris_tick++)) || true
          animate_debris "$debris_tick" "$band_row" "$x" "$band_h"
        fi
        frame_delay
        erase_sprite_overlap "$band_row" "$x" "$stride" "$band_h"
        scatter_debris "$band_row" "$x" "$stride" "$band_h" "$debris_tick"
        ((toggle++)) || true
        ((frame++)) || true
      fi
    done
  done

  ((debris_tick++)) || true
  animate_debris "$debris_tick"
  printf '%s' "$SHOW_CURSOR"
  clear_screen
}

# ── main ──────────────────────────────────────────────────────────────────────
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

# Need UTF-8 for the block-art sprite
if [[ -z "${LANG:-}" ]] || [[ ! "${LANG}" =~ [Uu][Tt][Ff]-?8 ]]; then
  export LANG="${LANG:-en_US.UTF-8}"
fi

animate