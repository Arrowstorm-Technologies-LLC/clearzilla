readonly -a ZILLA_WALK1=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_WALK2=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_BREATH=("${ZILLA_SPRITE[@]}")

readonly ZILLA_H=${#ZILLA_SPRITE[@]}

_sprite_width() {
  local -n _lines=$1
  local w=0
  for _l in "${_lines[@]}"; do
    ((${#_l} > w)) && w=${#_l}
  done
  echo "$w"
}

readonly ZILLA_W=$(_sprite_width ZILLA_SPRITE)
readonly MOUTH_COL=14   # column offset from sprite origin to fire origin (snout)
readonly ENABLE_FIRE=0  # fire breath disabled for now

readonly -a DEBRIS_CHARS=( '░' '▒' '▓' ':' '.' ',' '`' '~' '%' '#' '*' '+' 'x' '°' )
readonly DEBRIS_MIN=2
readonly DEBRIS_MAX=4
readonly ENABLE_DEBRIS_ANIM=1
readonly DEBRIS_ANIM_INTERVAL=3
readonly DEBRIS_ANIM_TAIL=22
readonly DEBRIS_ANIM_MAX=14   # cap particles redrawn per anim frame
readonly DEBRIS_TRACK_MAX=240 # keep sites tracked until dissolved, not column-wiped
readonly DEBRIS_DISSOLVE_STAGES=3
readonly DEBRIS_DISSOLVE_RATE=5   # dissolve budget scales with Godzilla progress
readonly DEBRIS_DISSOLVE_STEP_MAX=16
readonly DEBRIS_DISSOLVE_FINISH_MAX=32
readonly DEBRIS_DISSOLVE_DELAY_MS=10

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} — Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Godzilla sweeps the visible terminal band by band until clear.
EOF
}

# ── terminal helpers ──────────────────────────────────────────────────────────
get_dims() {
  local size rows cols
  rows=0 cols=0
  size=$(stty size 2>/dev/null || true)
  if [[ -n "$size" ]]; then
    rows=${size%% *}
    cols=${size##* }
  fi
  (( rows < 1 )) && rows=${LINES:-$(tput lines 2>/dev/null || echo 24)}
  (( cols < 1 )) && cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  (( rows < 1 )) && rows=24
  (( cols < 1 )) && cols=80
  (( rows > 128 )) && rows=128
  (( cols > 512 )) && cols=512
  TERM_ROWS=$rows
  TERM_COLS=$cols
}

band_height() {
  local band_row=$1
  local h=$(( TERM_ROWS - band_row + 1 ))
  (( h > ZILLA_H )) && h=$ZILLA_H
  (( h < 1 )) && h=1
  echo "$h"
}

frame_delay() {
  local extra=${1:-0}
  local ms=$(( (40 + extra) / SPEED ))
  (( ms < 3 )) && ms=3
  sleep "0.$(printf '%03d' "$ms")"
}

debris_dissolve_delay() {
  local ms=$(( DEBRIS_DISSOLVE_DELAY_MS / SPEED ))
  (( ms < 2 )) && ms=2
  sleep "0.$(printf '%03d' "$ms")"
}

breath_delay() {
  local ms=$(( 60 / SPEED ))
  (( ms < 4 )) && ms=4
  sleep "0.$(printf '%03d' "$ms")"
}

walk_stride() {
  local stride=$SPEED
  (( stride < 2 )) && stride=2
  echo "$stride"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

draw_sprite() {
  local -n lines=$1
  local row=$2 col=$3
  local h=${4:-$ZILLA_H}
  local i=0
  for line in "${lines[@]}"; do
    (( i >= h )) && break
    move_to $((row + i)) "$col"
    printf '%s' "$line"
    ((i++)) || true
  done
}

erase_sprite() {
  local row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local blank
  blank=$(printf '%*s' "$ZILLA_W" '')
  local i
  for ((i = 0; i < h; i++)); do
    move_to $((row + i)) "$col"
    printf '%s' "$blank"
  done
}

# Sparse ash particles — tracked for wake animation; prior bands fade as Godzilla steps down.
declare -a DEBRIS_SITES=()

debris_color() {
  local seed=$1 tick=$2
  case $(((seed + tick * 3) % 14)) in
    0) printf '%s' "$ORANGE" ;;
    1) printf '%s' "$RED" ;;
    2|3|4) printf '%s' "$ASH" ;;
    *) printf '%s' "$RUBBLE" ;;
  esac
}

debris_glyph() {
  local seed=$1 tick=$2
  local idx=$(( (seed + tick * 5) % ${#DEBRIS_CHARS[@]} ))
  printf '%s' "${DEBRIS_CHARS[$idx]}"
}

draw_debris_particle() {
  local r=$1 c=$2 seed=$3 tick=${4:-0}
  local ch color
  move_to "$r" "$c"
  ch=$(debris_glyph "$seed" "$tick")
  color=$(debris_color "$seed" "$tick")
  printf '%b%s%b' "$color" "$ch" "$RESET"
}

# True when a debris cell sits under the live Godzilla footprint.
debris_under_sprite() {
  local r=$1 c=$2 sprite_row=$3 sprite_col=$4 sprite_h=$5
  (( sprite_col < 1 || sprite_h < 1 )) && return 1
  (( r >= sprite_row && r < sprite_row + sprite_h && c >= sprite_col && c < sprite_col + ZILLA_W ))
}

prune_debris_tracking() {
  while (( ${#DEBRIS_SITES[@]} > DEBRIS_TRACK_MAX )); do
    DEBRIS_SITES=( "${DEBRIS_SITES[@]:1}" )
  done
}

debris_dissolve_glyph() {
  local seed=$1 stage=$2 tick=$3
  case "$stage" in
    0) debris_glyph "$seed" "$tick" ;;
    1)
      case $(((seed + tick) % 4)) in
        0) printf '.' ;;
        1) printf ',' ;;
        2) printf ':' ;;
        *) printf '`' ;;
      esac
      ;;
    2)
      case $(((seed + tick) % 3)) in
        0) printf '.' ;;
        1) printf ' ' ;;
        *) printf ',' ;;
      esac
      ;;
    *)
      printf ' '
      ;;
  esac
}

debris_dissolve_color() {
  local seed=$1 stage=$2 tick=$3
  case "$stage" in
    0) debris_color "$seed" "$tick" ;;
    1) printf '%s' "$ASH" ;;
    2) printf '%s' "$RUBBLE" ;;
    *) printf '%s' "$RESET" ;;
  esac
}

draw_debris_dissolve() {
  local r=$1 c=$2 seed=$3 stage=$4 tick=${5:-0}
  local ch color
  move_to "$r" "$c"
  ch=$(debris_dissolve_glyph "$seed" "$stage" "$tick")
  color=$(debris_dissolve_color "$seed" "$stage" "$tick")
  if (( stage >= DEBRIS_DISSOLVE_STAGES )); then
    printf '%b %b' "$RESET" "$RESET"
  else
    printf '%b%s%b' "$color" "$ch" "$RESET"
  fi
}

count_band_debris() {
  local band_row=$1
  local site site_band count=0
  for site in "${DEBRIS_SITES[@]}"; do
    read -r _ _ _ site_band _ <<< "$site"
    (( site_band == band_row )) && ((count++)) || true
  done
  echo "$count"
}

# Smolder wake debris and any band ash still cooling down.
animate_debris_wake() {
  local tick=$1 band_row=$2 band_x=$3 band_h=$4
  local sprite_row=${5:-0} sprite_col=${6:-0} sprite_h=${7:-0}
  local site r c seed site_band stage tail_start ch color animated=0
  tail_start=$(( band_x - DEBRIS_ANIM_TAIL ))
  (( tail_start < 1 )) && tail_start=1

  for site in "${DEBRIS_SITES[@]}"; do
    (( animated >= DEBRIS_ANIM_MAX )) && break
    read -r r c seed site_band stage <<< "$site"
    stage=${stage:-0}
    (( site_band != band_row )) && continue
    (( r < band_row || r >= band_row + band_h )) && continue
    debris_under_sprite "$r" "$c" "$sprite_row" "$sprite_col" "$sprite_h" && continue
    if (( stage == 0 )); then
      (( c >= band_x || c < tail_start )) && continue
      (( (seed + tick) % 2 != 0 )) && continue
    else
      (( (seed + tick + stage) % 2 != 0 )) && continue
    fi
    ch=$(debris_dissolve_glyph "$seed" "$stage" "$tick")
    move_to "$r" "$c"
    color=$(debris_dissolve_color "$seed" "$stage" "$tick")
    printf '%b%s%b' "$color" "$ch" "$RESET"
    ((animated++)) || true
  done
}

# Gracefully dissolve debris in random pockets — not a Godzilla-style column sweep.
dissolve_band_debris_batch() {
  local band_row=$1 band_h=$2 budget=$3 tick=$4
  local sprite_row=${5:-0} sprite_col=${6:-0} sprite_h=${7:-0}
  local -a candidates=() picked=() new_sites=()
  local site r c seed site_band stage next_stage
  local dissolved=0 i start found pr pc pseed pb ps pst

  (( budget < 1 )) && return 0

  for site in "${DEBRIS_SITES[@]}"; do
    read -r r c seed site_band stage <<< "$site"
    stage=${stage:-0}
    (( site_band != band_row )) && continue
    (( r < band_row || r >= band_row + band_h )) && continue
    debris_under_sprite "$r" "$c" "$sprite_row" "$sprite_col" "$sprite_h" && continue
    candidates+=( "$site" )
  done
  (( ${#candidates[@]} == 0 )) && return 0

  start=$(( (tick * 17 + band_row * 13) % ${#candidates[@]} ))
  for ((i = 0; i < ${#candidates[@]} && dissolved < budget; i++)); do
    site=${candidates[$(( (start + i * 7) % ${#candidates[@]} ))]}
    read -r r c seed site_band stage <<< "$site"
    stage=${stage:-0}
    found=0
    for pick in "${picked[@]}"; do
      read -r pr pc _ _ _ <<< "$pick"
      if (( r == pr && c == pc )); then
        found=1
        break
      fi
    done
    (( found )) && continue
    next_stage=$(( stage + 1 ))
    draw_debris_dissolve "$r" "$c" "$seed" "$next_stage" "$tick"
    picked+=( "$r $c $seed $site_band $next_stage" )
    ((dissolved++)) || true
  done
  (( dissolved == 0 )) && return 0

  for site in "${DEBRIS_SITES[@]}"; do
    read -r r c seed site_band stage <<< "$site"
    stage=${stage:-0}
    found=0
    for pick in "${picked[@]}"; do
      read -r pr pc pseed pb ps pst <<< "$pick"
      if (( r == pr && c == pc )); then
        found=1
        if (( pst < DEBRIS_DISSOLVE_STAGES )); then
          new_sites+=( "$pr $pc $pseed $pb $pst" )
        fi
        break
      fi
    done
    (( found )) || new_sites+=( "$site" )
  done
  DEBRIS_SITES=( "${new_sites[@]}" )
}

dissolve_step_budget() {
  local x=$1 max_x=$2
  local budget=$(( (x * DEBRIS_DISSOLVE_STEP_MAX * DEBRIS_DISSOLVE_RATE) / max_x ))
  (( budget < 2 )) && budget=2
  (( budget > DEBRIS_DISSOLVE_STEP_MAX )) && budget=$DEBRIS_DISSOLVE_STEP_MAX
  echo "$budget"
}

finish_band_dissolve() {
  local band_row=$1 band_h=$2
  local tick=0 remaining before remaining_after budget
  while true; do
    remaining=$(count_band_debris "$band_row")
    (( remaining == 0 )) && break
    (( tick > 512 )) && break
    ((tick++)) || true
    if (( ENABLE_DEBRIS_ANIM )); then
      animate_debris_wake "$tick" "$band_row" "$TERM_COLS" "$band_h"
    fi
    before=$remaining
    budget=$DEBRIS_DISSOLVE_FINISH_MAX
    (( remaining < budget )) && budget=$remaining
    dissolve_band_debris_batch "$band_row" "$band_h" "$budget" "$tick"
    remaining_after=$(count_band_debris "$band_row")
    (( remaining_after >= before )) && break
    debris_dissolve_delay
  done
}

# Erase any tracked debris still on screen after dissolve passes.
wipe_tracked_debris_sites() {
  local site r c seed site_band stage
  for site in "${DEBRIS_SITES[@]}"; do
    read -r r c seed site_band stage <<< "$site"
    move_to "$r" "$c"
    printf '%b %b' "$RESET" "$RESET"
  done
  DEBRIS_SITES=()
}

scatter_debris_in_zone() {
  local band_row=$1 col_start=$2 col_end=$3
  local h=${4:-$ZILLA_H} tick=${5:-0}
  local zone_w count i r c seed
  (( col_end < col_start )) && return 0
  zone_w=$(( col_end - col_start + 1 ))
  count=$(( DEBRIS_MIN + RANDOM % (DEBRIS_MAX - DEBRIS_MIN + 1) ))
  for ((i = 0; i < count; i++)); do
    r=$(( band_row + RANDOM % h ))
    c=$(( col_start + RANDOM % zone_w ))
    seed=$(( RANDOM * 997 + r * 31 + c * 17 + i * 13 ))
    if (( ENABLE_DEBRIS_ANIM )); then
      DEBRIS_SITES+=( "$r $c $seed $band_row 0" )
    fi
    draw_debris_particle "$r" "$c" "$seed" "$tick"
  done
}

scatter_debris() {
  local band_row=$1 col=$2 stride=$3
  local h=${4:-$ZILLA_H} tick=${5:-0}
  local wake_w=$stride
  (( wake_w > ZILLA_W )) && wake_w=$ZILLA_W
  (( wake_w < 1 )) && wake_w=1
  scatter_debris_in_zone "$band_row" "$col" $(( col + wake_w - 1 )) "$h" "$tick"
}

# The last stomp only seeds debris in its wake slice; fill the trailing overlap.
scatter_pass_tail() {
  local band_row=$1 last_x=$2 stride=$3 band_h=$4 tick=$5
  local tail_start=$(( last_x + stride ))
  local tail_end=$(( last_x + ZILLA_W - 1 ))
  (( tail_end > TERM_COLS )) && tail_end=$TERM_COLS
  scatter_debris_in_zone "$band_row" "$tail_start" "$tail_end" "$band_h" "$tick"
}

leave_stomp_wake() {
  local band_row=$1 col=$2 stride=$3 band_h=$4 tick=$5
  erase_sprite "$band_row" "$col" "$band_h"
  scatter_debris "$band_row" "$col" "$stride" "$band_h" "$tick"
}

draw_fire_beam() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local fire_len=$((TERM_COLS - col + 1))
  local i j
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) "$col"
    for ((j = 0; j < fire_len; j++)); do
      case $((j % 4)) in
        0) printf '%b~%b' "$RED" "$RESET" ;;
        1) printf '%b=%b' "$ORANGE" "$RESET" ;;
        2) printf '%b*%b' "$YELLOW" "$RESET" ;;
        3) printf '%b>%b' "$RED" "$RESET" ;;
      esac
    done
  done
}

scorch_band_right() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local fire_len=$((TERM_COLS - col + 1))
  local i
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) "$col"
    printf '%*s' "$fire_len" ''
  done
}

scorch_band() {
  local band_row=$1
  local h=${2:-$ZILLA_H}
  local i
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) 1
    printf '%*s' "$TERM_COLS" ''
  done
}

clear_screen() {
  printf '\033[2J\033[H'
}

# ── animation (paclear-style band sweep) ──────────────────────────────────────
# Godzilla is ZILLA_H lines tall. Each horizontal pass clears one full band
# before stepping down to the next band — exactly like paclear's pac-man sweep.
animate() {
  get_dims

  local diff_y=$(( TERM_ROWS - ZILLA_H ))
  (( diff_y < 0 )) && diff_y=0

  local y x frame=0 toggle=0 stride max_x walk_step=0 debris_tick=0
  local fire_col band_row band_h prev_band_row prev_band_h dissolve_budget
  local last_band_row=1 last_band_h=$ZILLA_H

  stride=$(walk_stride)
  max_x=$(( TERM_COLS - ZILLA_W ))
  (( max_x < 1 )) && max_x=1

  DEBRIS_SITES=()
  printf '%s' "$HIDE_CURSOR"

  for ((y = 0; y <= diff_y; y += ZILLA_H)); do
    band_row=$((y + 1))
    band_h=$(band_height "$band_row")
    last_band_row=$band_row
    last_band_h=$band_h
    if (( y > 0 )); then
      prev_band_row=$(( band_row - ZILLA_H ))
      prev_band_h=$(band_height "$prev_band_row")
    fi

    for ((x = 1; x <= max_x; x += stride)); do
      ((walk_step++)) || true

      if (( ENABLE_FIRE && toggle == 10 )); then
        draw_sprite ZILLA_BREATH "$band_row" "$x" "$band_h"
        if (( y > 0 )); then
          if (( ENABLE_DEBRIS_ANIM && walk_step % DEBRIS_ANIM_INTERVAL == 0 )); then
            animate_debris_wake "$debris_tick" "$prev_band_row" "$TERM_COLS" "$prev_band_h" \
              "$band_row" "$x" "$band_h"
          fi
          dissolve_budget=$(dissolve_step_budget "$x" "$max_x")
          dissolve_band_debris_batch "$prev_band_row" "$prev_band_h" "$dissolve_budget" "$debris_tick" \
            "$band_row" "$x" "$band_h"
        fi
        fire_col=$((x + MOUTH_COL))
        draw_fire_beam "$band_row" "$fire_col" "$band_h"
        breath_delay
        scorch_band_right "$band_row" "$fire_col" "$band_h"
        leave_stomp_wake "$band_row" "$x" "$stride" "$band_h" "$debris_tick"
        toggle=0
      else
        draw_sprite ZILLA_WALK1 "$band_row" "$x" "$band_h"
        if (( y > 0 )); then
          if (( ENABLE_DEBRIS_ANIM && walk_step % DEBRIS_ANIM_INTERVAL == 0 )); then
            animate_debris_wake "$debris_tick" "$prev_band_row" "$TERM_COLS" "$prev_band_h" \
              "$band_row" "$x" "$band_h"
          fi
          dissolve_budget=$(dissolve_step_budget "$x" "$max_x")
          dissolve_band_debris_batch "$prev_band_row" "$prev_band_h" "$dissolve_budget" "$debris_tick" \
            "$band_row" "$x" "$band_h"
        fi
        if (( ENABLE_DEBRIS_ANIM && walk_step % DEBRIS_ANIM_INTERVAL == 0 )); then
          ((debris_tick++)) || true
          animate_debris_wake "$debris_tick" "$band_row" "$x" "$band_h" \
            "$band_row" "$x" "$band_h"
        fi
        frame_delay
        leave_stomp_wake "$band_row" "$x" "$stride" "$band_h" "$debris_tick"
        (( ENABLE_DEBRIS_ANIM )) && prune_debris_tracking
        ((toggle++)) || true
        ((frame++)) || true
      fi
    done

    scatter_pass_tail "$band_row" "$max_x" "$stride" "$band_h" "$debris_tick"

    if (( y > 0 )); then
      finish_band_dissolve "$prev_band_row" "$prev_band_h"
    fi
  done

  # The last swept band never gets a following pass — dissolve its ash pocket by pocket.
  finish_band_dissolve "$last_band_row" "$last_band_h"
  wipe_tracked_debris_sites

  printf '%s' "$SHOW_CURSOR"
  clear_screen
}

# ── main ──────────────────────────────────────────────────────────────────────
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

# Need UTF-8 for the block-art sprite
if [[ -z "${LANG:-}" ]] || [[ ! "${LANG}" =~ [Uu][Tt][Ff]-?8 ]]; then
  export LANG="${LANG:-en_US.UTF-8}"
fi

animate