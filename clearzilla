#!/usr/bin/env bash
# clearzilla вҖ” Godzilla stomps in and fire-breaths your terminal clean
# Lightweight, dependency-free. Animation scales with terminal content.

set -euo pipefail

VERSION="0.3.1"

# в”Җв”Җ styling в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  YELLOW="\033[1;33m"
  RED="\033[1;31m"
  ORANGE="\033[38;5;208m"
  RESET="\033[0m"
  HIDE_CURSOR=$'\033[?25l'
  SHOW_CURSOR=$'\033[?25h'
else
  BOLD="" DIM="" GREEN="" YELLOW="" RED="" ORANGE="" RESET=""
  HIDE_CURSOR="" SHOW_CURSOR=""
fi

# в”Җв”Җ godzilla sprite (unicode block art, 24Г—39) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
readonly -a ZILLA_SPRITE=(
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ вЈӨвЎҖв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ вЈ¶вЈҝвЈҝвЈҝвЎҹв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҖвЈҖв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв  вЈҰвЈ„вЈӨвЈӨвЈ¶вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Үв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈ вЈӨвЈ вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҹв Ғв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈҖвЈҖвЈҷвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҹв Җв Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҲвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Ғв Җв Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җвў вЈӨвЈ„вЈҖвЈ»вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҸв Җв Җв Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв җв ҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Җв Җв Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈӨвЈӨвЈјвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҹв Җв Җв Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ§вЎҖв Җв Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ¬вЈқвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ„в Җв Җв Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈ¬вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Ӣв »вўҝвЈҝвЈҝвЈ·вЈ„в Җв Җ'
  'в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈ„в Җв Ҳвў»вЈҝвЈҝвЎ„в Җ'
  'в Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈӨвЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЎӨвЈјвЈҝвЈҝвЈ·в Җ'
  'в Җв Җв Җв Җв ҖвўҖвЈҙвЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҶв үв үв Ғв Җ'
  'в Җв Җв ҖвўҖвЈҫвЈҝвЈҝвЈҝвЈҚвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ§в Җв Җв Җ'
  'в Җв ҖвЈҙвЈҝвЈҝвЈҝвЈҝвЈјвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҶв Җв Җ'
  'вўҖвЈ вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв ҹв ӣв ӣвЈ»вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Үв Җв Җ'
  'в ёвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Ҹв Җв Җв Җв Җв Җвў№вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҹв Җв Җв Җ'
  'в ҳвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв Ҹв Ғв Җв Җв Җв Җв Җв Җв ҲвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҮв Җв Җв Җ'
  'в Җв »вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв ҹв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ§вЈ„в Җв Җ'
  'в Җв Җв Ҳв »вўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҒв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЎ„'
  'в Җв Җв Җв Җв Җв Җв Җв ёвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв Ҷв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв үв үв үв үв үв үв үв үв Ғ'
)

readonly -a ZILLA_WALK1=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_WALK2=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_BREATH=("${ZILLA_SPRITE[@]}")

readonly ZILLA_H=${#ZILLA_SPRITE[@]}

_sprite_width() {
  local -n _lines=$1
  local w=0
  for _l in "${_lines[@]}"; do
    ((${#_l} > w)) && w=${#_l}
  done
  echo "$w"
}

readonly ZILLA_W=$(_sprite_width ZILLA_SPRITE)
readonly MOUTH_COL=14   # column offset from sprite origin to fire origin (snout)

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} вҖ” Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Animation length scales with how much content is on screen.
EOF
}

# в”Җв”Җ terminal helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
get_dims() {
  local size rows cols
  rows=0 cols=0
  size=$(stty size 2>/dev/null || true)
  if [[ -n "$size" ]]; then
    rows=${size%% *}
    cols=${size##* }
  fi
  (( rows < 1 )) && rows=${LINES:-$(tput lines 2>/dev/null || echo 24)}
  (( cols < 1 )) && cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  (( rows < 1 )) && rows=24
  (( cols < 1 )) && cols=80
  (( rows > 128 )) && rows=128
  (( cols > 512 )) && cols=512
  TERM_ROWS=$rows
  TERM_COLS=$cols
}

frame_delay() {
  local ms=$(( 12 / SPEED ))
  (( ms < 1 )) && ms=1
  sleep "0.$(printf '%03d' "$ms")"
}

walk_stride() {
  local stride=$(( SPEED + 3 ))
  (( stride < 5 )) && stride=5
  (( ZILLA_W > 30 && stride < 6 )) && stride=6
  echo "$stride"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

draw_sprite() {
  local -n lines=$1
  local row=$2 col=$3
  local i=0
  for line in "${lines[@]}"; do
    move_to $((row + i)) "$col"
    printf '%s' "$line"
    ((i++)) || true
  done
}

erase_sprite() {
  local row=$1 col=$2
  local blank
  blank=$(printf '%*s' "$ZILLA_W" '')
  local i
  for ((i = 0; i < ZILLA_H; i++)); do
    move_to $((row + i)) "$col"
    printf '%s' "$blank"
  done
}

draw_fire_beam() {
  local band_row=$1 col=$2
  local fire_len=$((TERM_COLS - col + 1))
  local i j ch line
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < ZILLA_H; i++)); do
    line=""
    for ((j = 0; j < fire_len; j++)); do
      case $((j % 4)) in
        0) ch='~' ;;
        1) ch='=' ;;
        2) ch='*' ;;
        3) ch='>' ;;
      esac
      line+="$ch"
    done
    move_to $((band_row + i)) "$col"
    printf '%b%s%b' "$ORANGE" "$line" "$RESET"
  done
}

scorch_band_right() {
  local band_row=$1 col=$2
  local fire_len=$((TERM_COLS - col + 1))
  local i
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < ZILLA_H; i++)); do
    move_to $((band_row + i)) "$col"
    printf '%*s' "$fire_len" ''
  done
}

clear_screen() {
  printf '\033[2J\033[H'
}

enter_alt_screen() {
  printf '\033[?1049h\033[H'
}

leave_alt_screen() {
  printf '\033[?1049l'
}

# в”Җв”Җ animation (paclear-style band sweep) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Godzilla is ZILLA_H lines tall. Each horizontal pass clears one full band
# before stepping down to the next band вҖ” exactly like paclear's pac-man sweep.
animate() {
  get_dims

  local diff_y=$(( TERM_ROWS - ZILLA_H ))
  (( diff_y < 0 )) && diff_y=0

  local y x frame=0 toggle=0 stride max_x
  local fire_col

  stride=$(walk_stride)
  max_x=$(( TERM_COLS - ZILLA_W ))
  (( max_x < 1 )) && max_x=1

  enter_alt_screen
  printf '%s' "$HIDE_CURSOR"

  for ((y = 0; y <= diff_y; y += ZILLA_H)); do
    local band_row=$((y + 1))

    for ((x = 1; x <= max_x; x += stride)); do
      if (( toggle == 10 )); then
        draw_sprite ZILLA_BREATH "$band_row" "$x"
        fire_col=$((x + MOUTH_COL))
        draw_fire_beam "$band_row" "$fire_col"
        scorch_band_right "$band_row" "$fire_col"
        erase_sprite "$band_row" "$x"
        toggle=0
      else
        if (( frame % 2 == 0 )); then
          draw_sprite ZILLA_WALK1 "$band_row" "$x"
        else
          draw_sprite ZILLA_WALK2 "$band_row" "$x"
        fi
        frame_delay
        erase_sprite "$band_row" "$x"
        ((toggle++)) || true
        ((frame++)) || true
      fi
    done
  done

  printf '%s' "$SHOW_CURSOR"
  leave_alt_screen
  clear_screen
}

# в”Җв”Җ main в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

# Need UTF-8 for the block-art sprite
if [[ -z "${LANG:-}" ]] || [[ ! "${LANG}" =~ [Uu][Tt][Ff]-?8 ]]; then
  export LANG="${LANG:-en_US.UTF-8}"
fi

animate