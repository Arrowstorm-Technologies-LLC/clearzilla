#!/usr/bin/env bash
# clearzilla — Godzilla stomps in and fire-breaths your terminal clean
# Lightweight, dependency-free. Animation scales with terminal content.

set -euo pipefail

VERSION="0.1.0"

# ── styling ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  YELLOW="\033[1;33m"
  RED="\033[1;31m"
  ORANGE="\033[38;5;208m"
  RESET="\033[0m"
  HIDE_CURSOR=$'\033[?25l'
  SHOW_CURSOR=$'\033[?25h'
else
  BOLD="" DIM="" GREEN="" YELLOW="" RED="" ORANGE="" RESET=""
  HIDE_CURSOR="" SHOW_CURSOR=""
fi

# ── godzilla sprites (6 lines, 14 cols) ───────────────────────────────────────
readonly -a ZILLA_WALK1=(
  '   /‾‾‾‾‾/'
  '  ( o   o)'
  '  |   ^   |'
  '  |  /|\  |'
  '  |   |   |'
  '   /___/ '
)

readonly -a ZILLA_WALK2=(
  '   /‾‾‾‾‾/'
  '  ( o   o)'
  '  |   v   |'
  '   | / \ |'
  '  |       |'
  '   /___/ '
)

readonly -a ZILLA_BREATH=(
  '   /‾‾‾‾‾/'
  '  ( o   o)'
  '  | >~~~~ |'
  '  |  /|\  |'
  '  |   |   |'
  '   /___/ '
)

readonly ZILLA_H=${#ZILLA_WALK1[@]}
readonly ZILLA_W=14

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} — Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Animation length scales with how much content is on screen.
EOF
}

# ── terminal helpers ──────────────────────────────────────────────────────────
get_dims() {
  local size
  size=$(stty size 2>/dev/null || echo "24 80")
  TERM_ROWS=${size%% *}
  TERM_COLS=${size##* }
}

get_content_lines() {
  local row=0
  if [[ -t 1 ]] && exec 3<>/dev/tty 2>/dev/null; then
    printf '\033[6n' >&3
    # Short timeout — never block waiting for a reply in piped/script contexts
    IFS=';' read -rsd R -t 0.05 _ row <&3 2>/dev/null || true
    exec 3>&-
  fi
  if [[ -z "$row" || "$row" -eq 0 ]]; then
    row=$TERM_ROWS
  fi
  # At least one band; cap at visible terminal height
  if (( row < ZILLA_H )); then
    row=$ZILLA_H
  elif (( row > TERM_ROWS )); then
    row=$TERM_ROWS
  fi
  CONTENT_LINES=$row
}

frame_delay() {
  # Base 16ms; higher speed = shorter delay
  local ms=$(( 16 / SPEED ))
  (( ms < 1 )) && ms=1
  sleep "0.$(printf '%03d' "$ms")"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

draw_sprite() {
  local -n lines=$1
  local row=$2 col=$3 color=$4
  local i=0
  for line in "${lines[@]}"; do
    move_to $((row + i)) "$col"
    printf '%b%s%b' "$color" "$line" "$RESET"
    ((i++)) || true
  done
}

erase_block() {
  local row=$1 col=$2 width=$3 height=$4
  local blank
  blank=$(printf '%*s' "$width" '')
  local i=0
  for ((i = 0; i < height; i++)); do
    move_to $((row + i)) "$col"
    printf '%s' "$blank"
  done
}

draw_fire() {
  local row=$1 col=$2 length=$3
  local pattern i
  if (( length <= 0 )); then
    return
  fi
  pattern='~'
  move_to "$row" "$col"
  for ((i = 0; i < length; i++)); do
    case $((i % 4)) in
      0) printf '%b~%b' "$RED" "$RESET" ;;
      1) printf '%b=%b' "$ORANGE" "$RESET" ;;
      2) printf '%b*%b' "$YELLOW" "$RESET" ;;
      3) printf '%b>%b' "$RED" "$RESET" ;;
    esac
  done
}

burn_band() {
  local band_row=$1 mouth_col=$2
  local fire_len=$((TERM_COLS - mouth_col + 1))
  local i
  # Fire spans the mouth row and one below
  draw_fire "$band_row" "$mouth_col" "$fire_len"
  draw_fire $((band_row + 1)) "$mouth_col" "$fire_len"
  # Scorch the band behind the flame
  for ((i = 0; i < ZILLA_H; i++)); do
    move_to $((band_row - 2 + i)) "$mouth_col"
    printf '%*s' "$fire_len" ''
  done
}

clear_screen() {
  printf '\033[2J\033[H'
}

# ── animation ─────────────────────────────────────────────────────────────────
animate() {
  get_dims
  get_content_lines

  local bands=$(( (CONTENT_LINES + ZILLA_H - 1) / ZILLA_H ))
  local stride=$(( 2 + SPEED / 2 ))
  (( stride < 1 )) && stride=1

  local band x frame=0 breath_every
  # More content → more fire-breath pauses; fewer columns → breathe more often
  breath_every=$(( (TERM_COLS - ZILLA_W) / (4 + bands / 2) ))
  (( breath_every < 8 )) && breath_every=8

  printf '%s' "$HIDE_CURSOR"

  for ((band = bands - 1; band >= 0; band--)); do
    local band_row=$(( band * ZILLA_H + 1 ))
    local breathing=0

    # Entrance: tromp in from the left edge
    for ((x = -ZILLA_W; x <= TERM_COLS - ZILLA_W; x += stride)); do
      (( x < 1 )) && continue

      if (( x % breath_every == 0 )); then
        breathing=1
        draw_sprite ZILLA_BREATH "$band_row" "$x" "$GREEN"
        burn_band $((band_row + 2)) $((x + 8))
        frame_delay
        frame_delay
        erase_block "$band_row" "$x" "$ZILLA_W" "$ZILLA_H"
        breathing=0
      fi

      if (( frame % 2 == 0 )); then
        draw_sprite ZILLA_WALK1 "$band_row" "$x" "$GREEN"
      else
        draw_sprite ZILLA_WALK2 "$band_row" "$x" "$GREEN"
      fi
      frame_delay
      erase_block "$band_row" "$x" "$ZILLA_W" "$ZILLA_H"
      ((frame++)) || true
    done

    # Final blast across the band
    draw_sprite ZILLA_BREATH "$band_row" $((TERM_COLS - ZILLA_W - 2)) "$GREEN"
    burn_band $((band_row + 2)) $((TERM_COLS - ZILLA_W + 6))
    frame_delay
    erase_block "$band_row" $((TERM_COLS - ZILLA_W - 2)) "$TERM_COLS" "$ZILLA_H"
  done

  printf '%s' "$SHOW_CURSOR"
  clear_screen
}

# ── main ──────────────────────────────────────────────────────────────────────
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

animate