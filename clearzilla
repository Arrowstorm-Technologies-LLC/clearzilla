#!/usr/bin/env bash
# clearzilla — Godzilla fire-breaths your terminal clean
# Head anchored on the right; a fanning flame sweeps left, clearing only
# characters the fire has actually reached.

set -euo pipefail

VERSION="0.3.0"

# ── styling ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  DGREEN="\033[32m"
  YELLOW="\033[1;33m"
  RED="\033[1;31m"
  ORANGE="\033[38;5;208m"
  HOT="\033[38;5;226m"
  CORE="\033[38;5;196m"
  RESET="\033[0m"
  HIDE_CURSOR=$'\033[?25l'
  SHOW_CURSOR=$'\033[?25h'
else
  BOLD="" DIM="" GREEN="" DGREEN="" YELLOW="" RED="" ORANGE="" HOT="" CORE="" RESET=""
  HIDE_CURSOR="" SHOW_CURSOR=""
fi

# ── godzilla head (left-facing profile: dorsal fins, brow, snout, open jaw) ─
readonly -a ZILLA_HEAD=(
  '        /|/|/|'
  '       /       /'
  '      / .---.   /'
  '     | /     /  |'
  '     | | @  |   |'
  '     | |  --|   |'
  '     | /   /    |'
  '     | | ####>  |'
  '     | | >##<   |'
  '     |  /####/  |'
  '      /________/'
  '         |  |'
)

readonly HEAD_H=${#ZILLA_HEAD[@]}

_sprite_width() {
  local -n _lines=$1
  local w=0 len
  for _l in "${_lines[@]}"; do
    len=${#_l}
    (( len > w )) && w=$len
  done
  echo "$w"
}

readonly HEAD_W=$(_sprite_width ZILLA_HEAD)
# Mouth emitter: left side of head, row index within sprite (0-based)
readonly MOUTH_ROW_OFF=7
readonly MOUTH_COL_OFF=3

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} — Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Godzilla's head stays fixed on the right. His flame fans leftward,
clearing characters only as the fire front reaches them.
EOF
}

# ── terminal helpers ──────────────────────────────────────────────────────────
get_dims() {
  local size
  size=$(stty size 2>/dev/null || echo "24 80")
  TERM_ROWS=${size%% *}
  TERM_COLS=${size##* }
}

get_content_lines() {
  local row=0
  if [[ -t 1 ]] && exec 3<>/dev/tty 2>/dev/null; then
    printf '\033[6n' >&3
    IFS=';' read -rsd R -t 0.05 _ row <&3 2>/dev/null || true
    exec 3>&-
  fi
  if [[ -z "$row" || "$row" -eq 0 ]]; then
    row=$TERM_ROWS
  elif (( row > TERM_ROWS )); then
    row=$TERM_ROWS
  fi
  CONTENT_LINES=$row
}

frame_delay() {
  # More on-screen content → longer sweep
  local ms=$(( (18 + CONTENT_LINES / 4) / SPEED ))
  (( ms < 1 )) && ms=1
  sleep "0.$(printf '%03d' "$ms")"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

clear_screen() {
  printf '\033[2J\033[H'
}

draw_head() {
  local top_row=$1 left_col=$2
  local i=0
  for line in "${ZILLA_HEAD[@]}"; do
    move_to $((top_row + i)) "$left_col"
    printf '%b%s%b' "$GREEN" "$line" "$RESET"
    ((i++)) || true
  done
}

# Turbulent fan boundary — cone widens as flame travels left
fan_half_width() {
  local dist=$1 max_spread=$2 frame=$3
  local base=$(( 1 + dist / 2 ))
  local wave=$(( (dist * 3 + frame * 2) % 3 ))
  local lobe=$(( (dist / 5 + frame) % 2 ))
  local spread=$(( base + wave + lobe ))
  (( spread > max_spread )) && spread=$max_spread
  echo "$spread"
}

# Wispy outer flame tendrils (visual only — narrower than burn zone)
fan_wisp_width() {
  local dist=$1 max_spread=$2 frame=$3
  local spread
  spread=$(fan_half_width "$dist" "$max_spread" "$frame")
  echo $(( spread + 1 + (frame + dist) % 2 ))
}

# Pick fire glyph and color by distance from mouth and position in fan
fire_glyph() {
  local dist=$1 row_off=$2 frame=$3
  local slot=$(( (dist * 11 + row_off * 7 + frame * 5) % 12 ))
  local ch color

  if (( dist < 3 )); then
    case $((slot % 4)) in
      0) ch='*'; color=$HOT ;;
      1) ch='#'; color=$YELLOW ;;
      2) ch='*'; color=$CORE ;;
      *) ch='#'; color=$ORANGE ;;
    esac
  elif (( dist < 8 )); then
    case $((slot % 5)) in
      0) ch='~'; color=$ORANGE ;;
      1) ch='='; color=$RED ;;
      2) ch='^'; color=$YELLOW ;;
      3) ch='*'; color=$ORANGE ;;
      *) ch='~'; color=$RED ;;
    esac
  else
    case $((slot % 6)) in
      0) ch='~'; color=$RED ;;
      1) ch='>'; color=$ORANGE ;;
      2) ch='^'; color=$RED ;;
      3) ch='='; color=$DGREEN ;;
      4) ch='~'; color=$ORANGE ;;
      *) ch='>'; color=$RED ;;
    esac
  fi
  printf '%b%s%b' "$color" "$ch" "$RESET"
}

# ── animation ─────────────────────────────────────────────────────────────────
animate() {
  get_dims
  get_content_lines

  local head_col=$(( TERM_COLS - HEAD_W + 1 ))
  local head_row=$(( (CONTENT_LINES - HEAD_H) / 2 + 1 ))
  (( head_row < 1 )) && head_row=1
  if (( head_row + HEAD_H - 1 > TERM_ROWS )); then
    head_row=$(( TERM_ROWS - HEAD_H + 1 ))
  fi

  local mouth_row=$(( head_row + MOUTH_ROW_OFF ))
  local mouth_col=$(( head_col + MOUTH_COL_OFF ))

  local max_spread=$(( CONTENT_LINES / 2 ))
  (( max_spread < 2 )) && max_spread=2
  (( max_spread > TERM_ROWS / 2 )) && max_spread=$(( TERM_ROWS / 2 ))

  local max_reach=$(( mouth_col - 1 ))
  (( max_reach < 1 )) && max_reach=1

  local reach frame=0 col row dist spread wisp row_off d

  printf '%s' "$HIDE_CURSOR"
  draw_head "$head_row" "$head_col"

  for ((reach = 1; reach <= max_reach; reach++)); do
    # Scorch trail: only columns the flame has already passed
    for ((d = 1; d < reach; d++)); do
      col=$(( mouth_col - d ))
      (( col < 1 )) && continue
      spread=$(fan_half_width "$d" "$max_spread" "$frame")
      for ((row_off = -spread; row_off <= spread; row_off++)); do
        row=$(( mouth_row + row_off ))
        (( row < 1 || row > CONTENT_LINES )) && continue
        move_to "$row" "$col"
        printf ' '
      done
    done

    # Leading fire front — the flame hasn't passed here yet
    col=$(( mouth_col - reach ))
    if (( col >= 1 )); then
      spread=$(fan_half_width "$reach" "$max_spread" "$frame")
      for ((row_off = -spread; row_off <= spread; row_off++)); do
        row=$(( mouth_row + row_off ))
        (( row < 1 || row > CONTENT_LINES )) && continue
        move_to "$row" "$col"
        fire_glyph "$reach" "$row_off" "$frame"
      done

      # Nozzle glow — hot core fixed at the mouth opening
      for ((d = 0; d < 3; d++)); do
        col=$(( mouth_col - d ))
        (( col < 1 )) && continue
        for ((row_off = -1; row_off <= 1; row_off++)); do
          row=$(( mouth_row + row_off ))
          (( row < 1 || row > CONTENT_LINES )) && continue
          move_to "$row" "$col"
          fire_glyph "$d" "$row_off" $((frame + d))
        done
      done

      # Outer wisps ahead of the main front (visual flair, no clearing yet)
      if (( reach < max_reach )); then
        d=$(( reach + 1 ))
        col=$(( mouth_col - d ))
        if (( col >= 1 )); then
          wisp=$(fan_wisp_width "$d" "$max_spread" "$frame")
          for ((row_off = -wisp; row_off <= wisp; row_off++)); do
            # Skip rows already inside the solid burn cone
            spread=$(fan_half_width "$d" "$max_spread" "$frame")
            (( row_off >= -spread && row_off <= spread )) && continue
            row=$(( mouth_row + row_off ))
            (( row < 1 || row > CONTENT_LINES )) && continue
            move_to "$row" "$col"
            printf '%b~%b' "$DGREEN" "$RESET"
          done
        fi
      fi

      # Smoldering embers one step behind the front
      if (( reach > 1 )); then
        d=$(( reach - 1 ))
        col=$(( mouth_col - d ))
        spread=$(fan_half_width "$d" "$max_spread" $((frame + 1)))
        for ((row_off = -spread; row_off <= spread; row_off++)); do
          (( (row_off + frame) % 3 == 0 )) || continue
          row=$(( mouth_row + row_off ))
          (( row < 1 || row > CONTENT_LINES )) && continue
          move_to "$row" "$col"
          fire_glyph "$d" "$row_off" $((frame + 2))
        done
      fi
    fi

    draw_head "$head_row" "$head_col"
    frame_delay
    ((frame++)) || true
  done

  # Final frame: burn everything the fan covered, then full clear
  for ((d = 1; d <= max_reach; d++)); do
    col=$(( mouth_col - d ))
    (( col < 1 )) && continue
    spread=$(fan_half_width "$d" "$max_spread" "$frame")
    for ((row_off = -spread; row_off <= spread; row_off++)); do
      row=$(( mouth_row + row_off ))
      (( row < 1 || row > CONTENT_LINES )) && continue
      move_to "$row" "$col"
      printf ' '
    done
  done

  printf '%s' "$SHOW_CURSOR"
  clear_screen
}

# ── main ──────────────────────────────────────────────────────────────────────
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

animate