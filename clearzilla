  'в Җв Җв Җв Җв ҖвўҖвЈҙвЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҶв үв үв Ғв Җ'
  'в Җв Җв ҖвўҖвЈҫвЈҝвЈҝвЈҝвЈҚвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ§в Җв Җв Җ'
  'в Җв ҖвЈҙвЈҝвЈҝвЈҝвЈҝвЈјвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҶв Җв Җ'
  'вўҖвЈ вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв ҹв ӣв ӣвЈ»вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Үв Җв Җ'
  'в ёвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв Ҹв Җв Җв Җв Җв Җвў№вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҹв Җв Җв Җ'
  'в ҳвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв Ҹв Ғв Җв Җв Җв Җв Җв Җв ҲвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҮв Җв Җв Җ'
  'в Җв »вЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв ҹв Ӣв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ§вЈ„в Җв Җ'
  'в Җв Җв Ҳв »вўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҒв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЎ„'
  'в Җв Җв Җв Җв Җв Җв Җв ёвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЎҝв Ҷв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Ҳв үв үв үв үв үв үв үв үв Ғ'
)

readonly -a ZILLA_WALK1=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_WALK2=("${ZILLA_SPRITE[@]}")
readonly -a ZILLA_BREATH=("${ZILLA_SPRITE[@]}")

readonly ZILLA_H=${#ZILLA_SPRITE[@]}

_sprite_width() {
  local -n _lines=$1
  local w=0
  for _l in "${_lines[@]}"; do
    ((${#_l} > w)) && w=${#_l}
  done
  echo "$w"
}

readonly ZILLA_W=$(_sprite_width ZILLA_SPRITE)
readonly MOUTH_COL=14   # column offset from sprite origin to fire origin (snout)
readonly ENABLE_FIRE=0  # fire breath disabled for now

readonly -a DEBRIS_CHARS=( 'в–‘' 'в–’' 'в–“' ':' '.' ',' '`' '~' '%' '#' '*' '+' 'x' 'В°' )
readonly DEBRIS_MIN=2
readonly DEBRIS_MAX=5

SPEED=1
FAST=0

usage() {
  cat <<EOF
${BOLD}clearzilla${RESET} вҖ” Godzilla fire-breaths your terminal clean

${BOLD}Usage:${RESET}
  clearzilla              Stomp in and clear the screen
  clearzilla ${YELLOW}-s${RESET} ${DIM}<n>${RESET}            Speed multiplier (default: 1, higher = faster)
  clearzilla ${YELLOW}-f${RESET}                   Skip animation, clear immediately
  clearzilla ${YELLOW}-h${RESET}                   Show this help
  clearzilla ${YELLOW}-v${RESET}                   Show version

Godzilla sweeps the visible terminal band by band until clear.
EOF
}

# в”Җв”Җ terminal helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
get_dims() {
  local size rows cols
  rows=0 cols=0
  size=$(stty size 2>/dev/null || true)
  if [[ -n "$size" ]]; then
    rows=${size%% *}
    cols=${size##* }
  fi
  (( rows < 1 )) && rows=${LINES:-$(tput lines 2>/dev/null || echo 24)}
  (( cols < 1 )) && cols=${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}
  (( rows < 1 )) && rows=24
  (( cols < 1 )) && cols=80
  (( rows > 128 )) && rows=128
  (( cols > 512 )) && cols=512
  TERM_ROWS=$rows
  TERM_COLS=$cols
}

band_height() {
  local band_row=$1
  local h=$(( TERM_ROWS - band_row + 1 ))
  (( h > ZILLA_H )) && h=$ZILLA_H
  (( h < 1 )) && h=1
  echo "$h"
}

frame_delay() {
  local ms=$(( 25 / SPEED ))
  (( ms < 2 )) && ms=2
  sleep "0.$(printf '%03d' "$ms")"
}

breath_delay() {
  local ms=$(( 60 / SPEED ))
  (( ms < 4 )) && ms=4
  sleep "0.$(printf '%03d' "$ms")"
}

walk_stride() {
  local stride=$SPEED
  (( stride < 2 )) && stride=2
  echo "$stride"
}

move_to() {
  printf '\033[%d;%dH' "$1" "$2"
}

draw_sprite() {
  local -n lines=$1
  local row=$2 col=$3
  local h=${4:-$ZILLA_H}
  local i=0
  for line in "${lines[@]}"; do
    (( i >= h )) && break
    move_to $((row + i)) "$col"
    printf '%s' "$line"
    ((i++)) || true
  done
}

erase_sprite() {
  local row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local blank
  blank=$(printf '%*s' "$ZILLA_W" '')
  local i
  for ((i = 0; i < h; i++)); do
    move_to $((row + i)) "$col"
    printf '%s' "$blank"
  done
}

# Sparse ash particles вҖ” stored globally and animated until the final clear.
declare -a DEBRIS_SITES=()

debris_color() {
  local seed=$1 tick=$2
  case $(((seed + tick * 3) % 14)) in
    0) printf '%s' "$ORANGE" ;;
    1) printf '%s' "$RED" ;;
    2|3|4) printf '%s' "$ASH" ;;
    *) printf '%s' "$RUBBLE" ;;
  esac
}

animate_debris() {
  local tick=$1
  local site r c seed idx ch color
  for site in "${DEBRIS_SITES[@]}"; do
    read -r r c seed <<< "$site"
    idx=$(( (seed + tick * 5) % ${#DEBRIS_CHARS[@]} ))
    ch=${DEBRIS_CHARS[$idx]}
    move_to "$r" "$c"
    color=$(debris_color "$seed" "$tick")
    printf '%b%s%b' "$color" "$ch" "$RESET"
  done
}

scatter_debris() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local count=$(( DEBRIS_MIN + RANDOM % (DEBRIS_MAX - DEBRIS_MIN + 1) ))
  local i r c seed
  for ((i = 0; i < count; i++)); do
    r=$(( band_row + RANDOM % h ))
    c=$(( col + RANDOM % ZILLA_W ))
    seed=$(( RANDOM * 997 + r * 31 + c * 17 + i * 13 ))
    DEBRIS_SITES+=( "$r $c $seed" )
  done
}

draw_fire_beam() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local fire_len=$((TERM_COLS - col + 1))
  local i j
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) "$col"
    for ((j = 0; j < fire_len; j++)); do
      case $((j % 4)) in
        0) printf '%b~%b' "$RED" "$RESET" ;;
        1) printf '%b=%b' "$ORANGE" "$RESET" ;;
        2) printf '%b*%b' "$YELLOW" "$RESET" ;;
        3) printf '%b>%b' "$RED" "$RESET" ;;
      esac
    done
  done
}

scorch_band_right() {
  local band_row=$1 col=$2
  local h=${3:-$ZILLA_H}
  local fire_len=$((TERM_COLS - col + 1))
  local i
  if (( fire_len <= 0 )); then
    return
  fi
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) "$col"
    printf '%*s' "$fire_len" ''
  done
}

scorch_band() {
  local band_row=$1
  local h=${2:-$ZILLA_H}
  local i
  for ((i = 0; i < h; i++)); do
    move_to $((band_row + i)) 1
    printf '%*s' "$TERM_COLS" ''
  done
}

clear_screen() {
  printf '\033[2J\033[H'
}

# в”Җв”Җ animation (paclear-style band sweep) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Godzilla is ZILLA_H lines tall. Each horizontal pass clears one full band
# before stepping down to the next band вҖ” exactly like paclear's pac-man sweep.
animate() {
  get_dims

  local diff_y=$(( TERM_ROWS - ZILLA_H ))
  (( diff_y < 0 )) && diff_y=0

  local y x frame=0 toggle=0 stride max_x debris_tick=0
  local fire_col band_row band_h

  stride=$(walk_stride)
  max_x=$(( TERM_COLS - ZILLA_W ))
  (( max_x < 1 )) && max_x=1

  DEBRIS_SITES=()
  printf '%s' "$HIDE_CURSOR"

  for ((y = 0; y <= diff_y; y += ZILLA_H)); do
    band_row=$((y + 1))
    band_h=$(band_height "$band_row")

    for ((x = 1; x <= max_x; x += stride)); do
      ((debris_tick++)) || true
      animate_debris "$debris_tick"

      if (( ENABLE_FIRE && toggle == 10 )); then
        draw_sprite ZILLA_BREATH "$band_row" "$x" "$band_h"
        fire_col=$((x + MOUTH_COL))
        draw_fire_beam "$band_row" "$fire_col" "$band_h"
        breath_delay
        scorch_band_right "$band_row" "$fire_col" "$band_h"
        erase_sprite "$band_row" "$x" "$band_h"
        scatter_debris "$band_row" "$x" "$band_h"
        toggle=0
      else
        if (( frame % 2 == 0 )); then
          draw_sprite ZILLA_WALK1 "$band_row" "$x" "$band_h"
        else
          draw_sprite ZILLA_WALK2 "$band_row" "$x" "$band_h"
        fi
        frame_delay
        erase_sprite "$band_row" "$x" "$band_h"
        scatter_debris "$band_row" "$x" "$band_h"
        ((toggle++)) || true
        ((frame++)) || true
      fi
    done
  done

  ((debris_tick++)) || true
  animate_debris "$debris_tick"
  printf '%s' "$SHOW_CURSOR"
  clear_screen
}

# в”Җв”Җ main в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
while getopts 's:fhv' opt; do
  case "$opt" in
    s)
      SPEED=$OPTARG
      if ! [[ "$SPEED" =~ ^[0-9]+$ ]] || (( SPEED < 1 )); then
        echo "clearzilla: speed must be a positive integer" >&2
        exit 1
      fi
      ;;
    f) FAST=1 ;;
    h)
      usage
      exit 0
      ;;
    v)
      echo "clearzilla $VERSION"
      exit 0
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
done

if (( FAST )) || [[ ! -t 1 ]]; then
  clear_screen
  exit 0
fi

# Need UTF-8 for the block-art sprite
if [[ -z "${LANG:-}" ]] || [[ ! "${LANG}" =~ [Uu][Tt][Ff]-?8 ]]; then
  export LANG="${LANG:-en_US.UTF-8}"
fi

animate